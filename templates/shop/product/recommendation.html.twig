{% for key in ['related', 'also', 'together'] %}
    {% if recommendations[key] is defined and recommendations[key] is not empty %}
        <div class="container mb-6" role="region" aria-labelledby="recommendation-{{ key }}-heading">
            <h2 class="mb-5" id="recommendation-{{ key }}-heading">{{ ('eiling_io_sylius_battery_included.recommendation.' ~ key)|trans }}</h2>
            <div class="products-grid">
                {% for product in recommendations[key] %}
                    <div>{{ component('sylius_shop:product:card', { product: product, template: hookable_metadata.configuration.product_template|default('@SyliusShop/product/common/card.html.twig') }) }}</div>
                {% endfor %}
            </div>
        </div>
    {% endif %}
{% endfor %}
