{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block content %}
    <div class="container mt-4 mb-5">
        <div class="row mt-5">
            {# 1. Das Macro für die unendlichen Kategorien ganz oben definieren #}
            {% macro render_category(searchWord, filterLink, facet, catName, catData, parentPath) %}
                {% import _self as macros %}
                {% set currentPath = parentPath ? parentPath ~ '+>+' ~ catName : catName %}

                <li class="mb-1">
                    <a href="?search={{ searchWord }}&{{ filterLink }}&filter[{{ facet.fieldName|url_encode }}]={{ currentPath|replace({' ': '+'})|url_encode }}"
                       class="text-decoration-none d-block py-1 {% if catData.checked %}fw-bold text-sylius-green{% else %}text-muted{% endif %}"
                       style="font-size: 0.9rem;">
                        <span class="me-1">↳</span> {{ catName }} <span class="small opacity-50">({{ catData.count }})</span>
                    </a>

                    {% if catData.childs is defined and catData.childs|length > 0 %}
                        <ul class="list-unstyled ms-3 border-start ps-2">
                            {% for childName, childData in catData.childs %}
                                {{ macros.render_category(searchWord, filterLink, facet, childName, childData, currentPath) }}
                            {% endfor %}
                        </ul>
                    {% endif %}
                </li>
            {% endmacro %}

            {# 2. Der eigentliche Filter-Bereich #}
            <div class="col-12 col-lg-3 border-end pe-lg-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="h5 fw-bold mb-0 text-uppercase" style="letter-spacing: 1px;">{{ 'eiling_io_sylius_battery_included.search.filter'|trans }}</h4>
                    {% if filter|length > 0 %}
                        <a href="?search={{ searchWord }}" class="btn btn-link btn-sm text-muted p-0 text-decoration-none">
                            <span class="me-1">✕</span>{{ 'eiling_io_sylius_battery_included.search.reset'|trans }}
                        </a>
                    {% endif %}
                </div>

                {% if facets is defined and facets|length > 0 %}
                    <div class="filter-wrapper">
                        {% for facet in facets %}
                            <div class="mb-4 pb-3 border-bottom">
                                <label class="fw-bold mb-2 d-block text-dark small text-uppercase opacity-75">{{ facet.fieldLabel|default(facet.fieldName) }}</label>

                                {# --- SELECT / ATTRIBUTE FILTER --- #}
                                {% if facet.type == 'select' %}
                                    <div class="filter-list custom-scrollbar" style="max-height: 250px; overflow-y: auto;">
                                        {% for value in attribute(facet, 'values') %}
                                            <div class="mb-1">
                                                <a href="?search={{ searchWord }}&{{ filterLink }}&filter[{{ facet.fieldName|url_encode }}]={{ value.name }}"
                                                   class="d-flex justify-content-between align-items-center text-decoration-none py-1 px-2 rounded filter-item {% if value.checked %}active-filter{% else %}text-muted{% endif %}">
                                                    <span style="font-size: 0.95rem;">{{ value.name }}</span>
                                                    <span class="badge rounded-pill bg-light text-dark fw-normal" style="font-size: 0.75rem;">{{ value.count }}</span>
                                                </a>
                                            </div>
                                        {% endfor %}
                                    </div>

                                {# --- CATEGORY FILTER --- #}
                                {% elseif facet.type == 'category' %}
                                    {% import _self as macros %}
                                    <ul class="list-unstyled ms-1">
                                        {% for catName, catData in attribute(facet, 'categories') %}
                                            {{ macros.render_category(searchWord, filterLink, facet, catName, catData, "") }}
                                        {% endfor %}
                                    </ul>

                                {# --- PRICE RANGE --- #}
                                {% elseif facet.type == 'range' %}
                                    <form method="get" class="mt-2">
                                        <input type="hidden" name="search" value="{{ searchWord }}" />
                                        {% for filterKey, filterValue in filter %}
                                            {% if filterKey != facet.fieldName %}
                                                {% if filterValue is iterable %}
                                                    {% for subKey, subValue in filterValue %}<input type="hidden" name="filter[{{ filterKey }}][{{ subKey }}]" value="{{ subValue }}" />{% endfor %}
                                                {% else %}
                                                    <input type="hidden" name="filter[{{ filterKey }}]" value="{{ filterValue }}" />
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                        <div class="input-group input-group-sm mb-2">
                                            <span class="input-group-text bg-white border-secondary-subtle">€</span>
                                            <input type="number" name="filter[{{ facet.fieldName|url_encode }}][min]" class="form-control border-secondary-subtle" placeholder="Min" value="{{ filter[facet.fieldName]['min']|default(facet.min) }}">
                                            <input type="number" name="filter[{{ facet.fieldName|url_encode }}][max]" class="form-control border-secondary-subtle border-start-0" placeholder="Max" value="{{ filter[facet.fieldName]['max']|default(facet.max) }}">
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-outline-dark w-100 mt-1" style="font-size: 0.75rem;">{{ 'eiling_io_sylius_battery_included.search.filter_button'|trans }}</button>
                                    </form>

                                {% elseif facet.type == 'rating' %}
                                    <div class="filter-list">
                                        {% for value in attribute(facet, 'ratings') %}
                                            <a href="?search={{ searchWord }}&{{ filterLink }}&filter[{{ facet.fieldName|url_encode }}]={{ value.name }}"
                                               class="text-decoration-none d-flex align-items-center py-1 {% if value.checked %}text-sylius-green fw-bold{% else %}text-muted{% endif %}">
                                                <div class="text-warning me-2" style="letter-spacing: 2px; font-size: 1.1rem;">
                                                    {% for i in 1..5 %}
                                                        {{ i <= value.name ? '★' : '☆' }}
                                                    {% endfor %}
                                                </div>
                                                <span class="small">({{ value.count }})</span>
                                            </a>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-muted small">{{ 'eiling_io_sylius_battery_included.search.no_filters'|trans }}</div>
                {% endif %}
            </div>

            <div class="col-12 col-lg-9">
                <h1>{{ 'eiling_io_sylius_battery_included.search.results_for'|trans({'%searchWord%': searchWord}) }}</h1>
                <div class="row flex-column flex-md-row align-items-end justify-content-end gap-2 gap-md-0 mb-5">
                    <div class="products-grid">
                        {% for product in products %}
                            <div>{{ component('sylius_shop:product:card', { product: product, template: hookable_metadata.configuration.product_template|default('@SyliusShop/product/common/card.html.twig') }) }}</div>
                        {% else %}
                            <div style="grid-column: 1 / -1; text-align: center; color: #888;">
                                {{ 'eiling_io_sylius_battery_included.search.no_products'|trans }}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        <ul class="pagination justify-content-center mt-4">
            {# Previous Button #}
            <li class="page-item{% if currentPage == 1 %} disabled{% endif %}">
                <a class="page-link" href="?search={{ searchWord }}&page={{ currentPage - 1 }}" tabindex="-1">Previous</a>
            </li>

            {# Pages #}
            {% for page in 1..maxPages %}
                <li class="page-item{% if page == currentPage %} active{% endif %}">
                    {% if page == currentPage %}
                        <span class="page-link">{{ page }}</span>
                    {% else %}
                        <a class="page-link" href="?search={{ searchWord }}&page={{ page }}">{{ page }}</a>
                    {% endif %}
                </li>
            {% endfor %}

            {# Next Button #}
            <li class="page-item{% if currentPage == maxPages %} disabled{% endif %}">
                <a class="page-link" href="?search={{ searchWord }}&page={{ currentPage + 1 }}">Next</a>
            </li>
        </ul>
    </div>

{% endblock %}