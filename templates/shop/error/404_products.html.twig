{% if products is not empty %}
    <div class="container mb-6" role="region" aria-labelledby="error-404-products-heading">
        <h2 class="mb-5 text-center" id="error-404-products-heading">{{ 'eiling_io_sylius_battery_included.error404.products_heading'|trans }}</h2>
        <div class="products-grid">
            {% for product in products %}
                <div>{{ component('sylius_shop:product:card', { product: product, template: hookable_metadata.configuration.product_template|default('@SyliusShop/product/common/card.html.twig') }) }}</div>
            {% endfor %}
        </div>
    </div>
{% endif %}
