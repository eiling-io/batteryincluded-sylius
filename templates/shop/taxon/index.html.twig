{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% macro render_category(filterLink, facet, catName, catData, parentPath) %}
    {% import _self as macros %}
    {% set currentPath = parentPath ? parentPath ~ '+>+' ~ catName : catName %}
    <li class="mb-1">
        <a href="?{{ filterLink }}&filter[{{ facet.fieldName|url_encode }}]={{ currentPath|replace({' ': '+'})|url_encode }}"
           class="text-decoration-none d-block py-1 {% if catData.checked %}fw-bold text-sylius-green{% else %}text-muted{% endif %}"
           style="font-size: 0.9rem;">
            <span class="me-1">↳</span> {{ catName }} <span class="small opacity-50">({{ catData.count }})</span>
        </a>
        {% if catData.childs is defined and catData.childs|length > 0 %}
            <ul class="list-unstyled ms-3 border-start ps-2">
                {% for childName, childData in catData.childs %}
                    {{ macros.render_category(filterLink, facet, childName, childData, currentPath) }}
                {% endfor %}
            </ul>
        {% endif %}
    </li>
{% endmacro %}

{% block content %}
    <div class="container mt-4 mb-5">
        <h1 class="mb-4">{{ taxon.name }}</h1>

        <div class="row mt-3">
            <div class="col-12 col-lg-3 border-end pe-lg-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="h5 fw-bold mb-0 text-uppercase" style="letter-spacing: 1px;">
                        {{ 'eiling_io_sylius_battery_included.search.filter'|trans }}
                    </h4>
                    {% if filter|length > 0 %}
                        <a href="?" class="btn btn-link btn-sm text-muted p-0 text-decoration-none">
                            <span class="me-1">✕</span>{{ 'eiling_io_sylius_battery_included.search.reset'|trans }}
                        </a>
                    {% endif %}
                </div>

                {% if facets is defined and facets|length > 0 %}
                    <div class="filter-wrapper">
                        {% for facet in facets %}
                            {% if facet.type != 'category' %}
                                <div class="mb-4 pb-3 border-bottom">
                                <label class="fw-bold mb-2 d-block text-dark small text-uppercase opacity-75">
                                    {{ facet.fieldLabel|default(facet.fieldName) }}
                                </label>

                                {% if facet.type == 'select' %}
                                    <div class="filter-list custom-scrollbar" style="max-height: 250px; overflow-y: auto;">
                                        {% for value in attribute(facet, 'values') %}
                                            <div class="mb-1">
                                                <a href="?{{ filterLink }}&filter[{{ facet.fieldName|url_encode }}]={{ value.name }}"
                                                   class="d-flex justify-content-between align-items-center text-decoration-none py-1 px-2 rounded filter-item {% if value.checked %}active-filter{% else %}text-muted{% endif %}">
                                                    <span style="font-size: 0.95rem;">{{ value.name }}</span>
                                                    <span class="badge rounded-pill bg-light text-dark fw-normal" style="font-size: 0.75rem;">{{ value.count }}</span>
                                                </a>
                                            </div>
                                        {% endfor %}
                                    </div>

                                {% elseif facet.type == 'range' %}
                                    <form method="get" class="mt-2">
                                        {% for filterKey, filterValue in filter %}
                                            {% if filterKey != facet.fieldName %}
                                                {% if filterValue is iterable %}
                                                    {% for subKey, subValue in filterValue %}
                                                        <input type="hidden" name="filter[{{ filterKey }}][{{ subKey }}]" value="{{ subValue }}" />
                                                    {% endfor %}
                                                {% else %}
                                                    <input type="hidden" name="filter[{{ filterKey }}]" value="{{ filterValue }}" />
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                        <div class="input-group input-group-sm mb-2">
                                            <span class="input-group-text bg-white border-secondary-subtle">€</span>
                                            <input type="number" name="filter[{{ facet.fieldName|url_encode }}][min]" class="form-control border-secondary-subtle" placeholder="{{ 'eiling_io_sylius_battery_included.filter.price_min'|trans }}" value="{{ filter[facet.fieldName]['min']|default(facet.min|round(0, 'floor')) }}">
                                            <input type="number" name="filter[{{ facet.fieldName|url_encode }}][max]" class="form-control border-secondary-subtle border-start-0" placeholder="{{ 'eiling_io_sylius_battery_included.filter.price_max'|trans }}" value="{{ filter[facet.fieldName]['max']|default(facet.max|round(0, 'ceil')) }}">
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-outline-dark w-100 mt-1" style="font-size: 0.75rem;">
                                            {{ 'eiling_io_sylius_battery_included.search.filter_button'|trans }}
                                        </button>
                                    </form>

                                {% elseif facet.type == 'rating' %}
                                    <div class="filter-list">
                                        {% for value in attribute(facet, 'ratings') %}
                                            <a href="?{{ filterLink }}&filter[{{ facet.fieldName|url_encode }}]={{ value.name }}"
                                               class="text-decoration-none d-flex align-items-center py-1 {% if value.checked %}text-sylius-green fw-bold{% else %}text-muted{% endif %}">
                                                <div class="text-warning me-2" style="letter-spacing: 2px; font-size: 1.1rem;">
                                                    {% for i in 1..5 %}{{ i <= value.name ? '★' : '☆' }}{% endfor %}
                                                </div>
                                                <span class="small">({{ value.count }})</span>
                                            </a>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="col-12 col-lg-9">
                {{ include('@EilingIoSyliusBatteryIncludedPlugin/shop/_includes/_sort_bar.html.twig') }}
                {% if products|length > 0 %}
                    <div class="products-grid">
                        {% for product in products %}
                            {{ component('sylius_shop:product:card', { product: product, template: '@SyliusShop/product/common/card.html.twig' }) }}
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-muted text-center py-5">
                        {{ 'eiling_io_sylius_battery_included.search.no_products'|trans }}
                    </div>
                {% endif %}

                {% if maxPages > 1 %}
                    <ul class="pagination justify-content-center mt-4">
                        <li class="page-item{% if currentPage == 1 %} disabled{% endif %}">
                            <a class="page-link" href="?{{ filterLink }}{% if sort %}&sort={{ sort|url_encode }}{% endif %}&page={{ currentPage - 1 }}">{{ 'eiling_io_sylius_battery_included.pagination.previous'|trans }}</a>
                        </li>
                        {% for page in 1..maxPages %}
                            <li class="page-item{% if page == currentPage %} active{% endif %}">
                                {% if page == currentPage %}
                                    <span class="page-link">{{ page }}</span>
                                {% else %}
                                    <a class="page-link" href="?{{ filterLink }}{% if sort %}&sort={{ sort|url_encode }}{% endif %}&page={{ page }}">{{ page }}</a>
                                {% endif %}
                            </li>
                        {% endfor %}
                        <li class="page-item{% if currentPage == maxPages %} disabled{% endif %}">
                            <a class="page-link" href="?{{ filterLink }}{% if sort %}&sort={{ sort|url_encode }}{% endif %}&page={{ currentPage + 1 }}">{{ 'eiling_io_sylius_battery_included.pagination.next'|trans }}</a>
                        </li>
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
