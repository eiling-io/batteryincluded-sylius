{# @EilingIoSyliusBatteryIncludedPlugin/shop/header/_searchbox.html.twig #}

<div class="col-auto d-none d-md-block ms-2 me-auto">
    <div style="width: 750px;">
        <form action="{{ path('eiling_io_sylius_battery_included_search') }}" method="get">
            <div class="input-group input-group-sm position-relative">
                <input type="text"
                       name="search"
                       class="form-control border-secondary"
                       placeholder="Produkte suchen..."
                       aria-label="Suchen">

                <button class="btn btn-primary px-3 rounded-end" type="submit">
                    <i class="bi bi-search text-white"></i>
                    <span class="d-none d-lg-inline ms-1 text-white fw-medium">Suchen</span>
                </button>
                <div id="search-overlay" class="position-absolute bg-white border rounded shadow" style="display:none; z-index: 1050; width: 100%; left: 0; top: 100%; max-height: 400px; overflow-y: auto;"></div>
            </div>
        </form>
    </div>
</div>

<style>
    .row.align-items-center > .col:first-child {
        flex: 0 0 auto !important;
        width: auto !important;
    }
    #search-overlay {
        min-height: 60px;
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const input = document.querySelector('input[name="search"]');
    const overlay = document.getElementById('search-overlay');
    let overlayActive = false;

    function showOverlay() {
        overlay.style.display = 'block';
        overlay.innerHTML = '<div class="text-center py-3"><div class="spinner-border text-primary" role="status"></div></div>';
        fetch('{{ path('eiling_io_sylius_battery_included_search_ajax') }}?search=' + encodeURIComponent(input.value))
            .then(r => r.text())
            .then(html => {
                overlay.innerHTML = html;
            });
    }

    function hideOverlay() {
        overlay.style.display = 'none';
    }

    input.addEventListener('focus', function() {
        showOverlay();
    });

    input.addEventListener('input', function() {
        showOverlay();
    });

    input.addEventListener('blur', function() {
        setTimeout(function() {
            if (!overlayActive) hideOverlay();
        }, 150);
    });

    overlay.addEventListener('mousedown', function() {
        overlayActive = true;
    });
    overlay.addEventListener('mouseup', function() {
        overlayActive = false;
        input.focus();
    });
});
</script>
